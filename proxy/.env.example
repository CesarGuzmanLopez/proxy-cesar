# Proxy Configuration
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to version control — secrets are injected via GitHub Actions deploy

# Server
PROXY_PORT=9110
PROXY_API_KEY=your-bearer-token-here
# PROXY_API_KEYS=key1,key2,key3  # Multiple keys for multi-user (overrides PROXY_API_KEY)

# Database
DATABASE_URL=sqlite+aiosqlite:///./proxy.db

# Cache (Redis/Valkey)
VALKEY_URL=valkey://localhost:6380

# Provider API Keys
# Single key (default):
OPENCODE_API_KEY=your-opencode-key-here
DEEPSEEK_API_KEY=sk-253bc9839fed46bb81554774d0f2783a
GROQ_API_KEY=your-groq-key-here
OPENROUTER_API_KEY=your-openrouter-key-here
PRUNA_API_KEY=your-pruna-key-here

# Key slot rotation (optional, for rate limit distribution):
# Each additional key gets a suffix _2, _3, etc.
# Conversations are pinned to a slot by conversation_id hash.
# Same conversation always uses the same slot.
# Example:
# OPENCODE_API_KEY_2=your-second-opencode-key
# DEEPSEEK_API_KEY_2=your-second-deepseek-key

# Optional: Disabled Providers (comma-separated)
DISABLED_PROVIDERS=

# Optional: Log File Location
LOG_FILE=/var/log/proxy-cesar/proxy.log
