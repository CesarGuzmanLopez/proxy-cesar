# Proxy Determinista Multi-Modelo — Environment Variables
# Copy to .env and fill in your values.

# ── Proxy ─────────────────────────────────────────────────────────────────────
PROXY_HOST=127.0.0.1
PROXY_PORT=9110
# Generate with: openssl rand -hex 32
# Leave empty for dev mode (no auth required)
PROXY_API_KEY=sk-proxy-change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://tudominio.com,vscode-webview://*

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://proxy:proxy@localhost:5432/proxy_db
# SQLite (development / single-user):
DATABASE_URL=sqlite+aiosqlite:///./proxy.db

# ── Cache / Broker (Valkey/Redis) ─────────────────────────────────────────────
# Native Redis (plata):     valkey://localhost:6380
# Docker Redis (deepbde):   valkey://localhost:6379
VALKEY_URL=valkey://localhost:6380

# ── KeyClaw ───────────────────────────────────────────────────────────────────
# Disabled by default — causes SSL issues when active
KEYCLAW_ENABLED=false

# ── Provider API Keys ─────────────────────────────────────────────────────────
OPENCODE_API_KEY=opencode-token-here
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx
PRUNA_API_KEY=pru-xxxxxxxxxxxx

# ── Provider Control ──────────────────────────────────────────────────────
# Disable specific providers to force fallback to alternatives.
# Comma-separated. Example: DISABLED_PROVIDERS=opencode-go,deepseek
DISABLED_PROVIDERS=

# ── Rate Limiting (requests per minute per pseudo-model) ─────────────────────
# RATE_LIMIT_pensamiento-profundo-caro=5
# RATE_LIMIT_tareas-avanzadas=20
# RATE_LIMIT_normal=60
# RATE_LIMIT_deep-flash=120
# RATE_LIMIT_flash-lowcost=200
# RATE_LIMIT_vision=15
# RATE_LIMIT_compactador=5

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── Client Configuration (on your machine, NOT on the server) ─────────────────
# export CESAR_PROXY_URL="https://proxy.tudominio.com/v1"
# export CESAR_PROXY_KEY="sk-proxy-xxxxxxxxxxxxxxxxxxxx"
