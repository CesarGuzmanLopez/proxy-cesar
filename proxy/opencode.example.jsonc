{
  "$schema": "https://opencode.ai/config.json",
  "model": "cesar-proxy/gpt-4o",
  "provider": {
    "cesar-proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "${CESAR_PROXY_URL}",
        "apiKey": "${CESAR_PROXY_KEY}"
      },
      "models": {
        "pensamiento-profundo-caro": {
          "name": "pensamiento-profundo-caro",
          "capabilities": {
            "tools": true,
            "vision": false,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true
          }
        },
        "tareas-avanzadas": {
          "name": "tareas-avanzadas",
          "capabilities": {
            "tools": true,
            "vision": false,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true
          }
        },
        "vision": {
          "name": "vision",
          "capabilities": {
            "tools": true,
            "vision": true,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": false
          }
        },
        "normal": {
          "name": "normal",
          "capabilities": {
            "tools": true,
            "vision": false,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true
          }
        },
        "normal-gratis": {
          "name": "normal-gratis",
          "capabilities": {
            "tools": true,
            "vision": false,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": false
          }
        },
        "massive-fast": {
          "name": "massive-fast",
          "capabilities": {
            "tools": true,
            "vision": false,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true
          }
        },
        "flash-lowcost": {
          "name": "flash-lowcost",
          "capabilities": {
            "tools": true,
            "vision": false,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true
          }
        },
        "compactador": {
          "name": "compactador",
          "capabilities": {
            "tools": true,
            "vision": false,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": false
          }
        }
      }
    }
  }
}